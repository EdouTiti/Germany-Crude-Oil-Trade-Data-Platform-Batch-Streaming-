    create or replace table `zoomcampde2026`.`Germany_oil_analytics`.`fact_oil_trade_germany`
      
    
    

    
    OPTIONS()
    as (
      with imports as (
    select *
    from `zoomcampde2026`.`Germany_oil_analytics`.`stg_germany_crude_oil_imports`
)

select
    year,
    date(year, 1, 1) as date,
    country_id,
    partner_id,
    to_hex(md5(to_json_string(struct(
        '',
        coalesce(commodity_description, '')
    )))) as commodity_id,
    quantity_unit,
    trade_direction,
    count(*) as import_record_count,
    sum(quantity) as total_quantity,
    sum(trade_value) as total_trade_value,
    safe_divide(sum(trade_value), nullif(sum(quantity), 0)) as trade_value_per_unit
from imports
group by
    year,
    date,
    country_id,
    partner_id,
    commodity_id,
    quantity_unit,
    trade_direction
    );
  
[0m18:47:42.047788 [debug] [Thread-2 (]: Writing runtime sql for node "model.germany_crude_oil_trade.dim_commodity"
[0m18:47:42.056755 [debug] [Thread-2 (]: On model.germany_crude_oil_trade.dim_commodity: /* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "germany_crude_oil_trade", "target_name": "dev", "node_id": "model.germany_crude_oil_trade.dim_commodity"} */

  
    

    create or replace table `zoomcampde2026`.`Germany_oil_analytics`.`dim_commodity`
      
    
    

    
    OPTIONS()
    as (
      with germany_commodities as (
    select distinct
        cast(null as string) as hs_code,
        commodity_description,
        'germany_imports' as commodity_source
    from `zoomcampde2026`.`Germany_oil_analytics`.`stg_germany_crude_oil_imports`
    where commodity_description is not null
),

global_commodities as (
    select distinct
        hs_code,
        product_description as commodity_description,
        'global_trade' as commodity_source
    from `zoomcampde2026`.`Germany_oil_analytics`.`stg_global_oil_trade`
    where hs_code is not null
       or product_description is not null
),

unioned as (
    select * from germany_commodities
    union distinct
    select * from global_commodities
)

select
    to_hex(md5(to_json_string(struct(
        coalesce(hs_code, ''),
        coalesce(commodity_description, '')
    )))) as commodity_id,
    commodity_description,
    hs_code,
    string_agg(distinct commodity_source, ', ' order by commodity_source) as commodity_sources
from unioned
group by
    commodity_id,
    commodity_description,
    hs_code
    );
  
