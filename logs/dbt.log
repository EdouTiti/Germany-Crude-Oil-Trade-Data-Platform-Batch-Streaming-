    create or replace table `zoomcampde2026`.`Germany_oil_analytics`.`dim_country`
      
    
    

    
    OPTIONS()
    as (
      with country_aliases as (
    select *
    from `zoomcampde2026`.`Germany_oil_analytics`.`stg_country_name_mapping`
),

ranked_countries as (
    select
        country_id,
        country_name,
        short_name,
        row_number() over (
            partition by country_id
            order by
                length(country_name),
                country_name,
                short_name
        ) as country_name_rank,
        count(*) over (partition by country_id) as alias_count
    from country_aliases
)

select
    country_id,
    country_name,
    short_name as primary_short_name,
    alias_count
from ranked_countries
where country_name_rank = 1
    );
  
