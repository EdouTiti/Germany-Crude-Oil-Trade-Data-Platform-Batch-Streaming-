  create or replace view `zoomcampde2026`.`Germany_oil_analytics`.`stg_germany_crude_oil_imports`
  OPTIONS()
  as with source as (
    select *
    from `zoomcampde2026`.`Germany_oil_data`.`germany_crude_oil_imports_clean`
),

numbered as (
    select
        *,
        row_number() over (
            partition by
                year,
                country,
                country_id,
                partner,
                partner_id,
                partner2,
                commodity_description,
                quantity,
                quantity_unit,
                trade_value,
                trade_direction
            order by
                year,
                country,
                country_id,
                partner,
                partner_id,
                partner2,
                commodity_description,
                quantity,
                quantity_unit,
                trade_value,
                trade_direction
        ) as duplicate_sequence
    from source
)

select
    to_hex(md5(concat(to_json_string(struct(
        year,
        country_id,
        partner_id,
        commodity_description,
        quantity,
        trade_value,
        duplicate_sequence
    )), '#', cast(duplicate_sequence as string)))) as germany_import_record_id,
    year,
    country,
    upper(country_id) as country_id,
    partner,
    upper(partner_id) as partner_id,
    partner2,
    commodity_description,
    quantity,
    quantity_unit,
    trade_value,
    trade_direction
from numbered;


